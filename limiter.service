[Unit]
Description=Limiter GPU Power Monitor
After=multi-user.target

[Service]
Type=simple
ExecStart=/usr/local/bin/limiter.sh
Restart=always
RestartSec=10

[Install]
WantedBy=multi-user.target


# Install and enable the service

# sudo nano /etc/systemd/system/limiter.service
# sudo systemctl daemon-reload
# sudo systemctl enable limiter
# sudo systemctl start limiter
# sudo systemctl status limiter
# journalctl -u limiter -f
